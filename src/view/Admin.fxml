<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.AdminController"
            prefWidth="500" prefHeight="450">

    <children>

        <!-- Title -->
        <Label layoutX="180" layoutY="25" text="Admin Panel">
            <font>
                <Font name="Verdana" size="20" />
            </font>
        </Label>

        <!-- Users list -->
        <ListView fx:id="userList"
                  layoutX="40" layoutY="80"
                  prefWidth="420" prefHeight="220" />

        <!-- Add user field -->
        <TextField fx:id="newUserField"
                   layoutX="40" layoutY="320"
                   prefWidth="200"
                   promptText="Enter new username" />

        <!-- Add user button -->
        <Button fx:id="addUserButton"
                layoutX="260" layoutY="320"
                prefWidth="90"
                text="Add"
                onAction="#addUser" />

        <!-- Delete user button -->
        <Button fx:id="deleteUserButton"
                layoutX="360" layoutY="320"
                prefWidth="100"
                text="Delete"
                onAction="#deleteUser" />

        <!-- Logout button -->
        <Button fx:id="logoutButton"
                layoutX="200" layoutY="380"
                prefWidth="100"
                text="Logout"
                onAction="#logout" />

    </children>

</AnchorPane>
