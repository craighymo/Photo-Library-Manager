<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.SearchController">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="15">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

            <Button text="Back" onAction="#goBack"/>
            <Button text="Logout" onAction="#logout"/>

            <Label text="Photo Search"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- MAIN CENTER CONTENT -->
    <center>
        <VBox spacing="20">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

            <!-- DATE RANGE SEARCH -->
            <TitledPane text="Search by Date Range" expanded="false">
                <content>
                    <VBox spacing="10">
                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                        <HBox spacing="10">
                            <Label text="Start Date:"/>
                            <DatePicker fx:id="startDate" prefWidth="200"/>
                        </HBox>

                        <HBox spacing="10">
                            <Label text="End Date:"/>
                            <DatePicker fx:id="endDate" prefWidth="200"/>
                        </HBox>
                    </VBox>
                </content>
            </TitledPane>

            <!-- TAG SEARCH -->
            <TitledPane text="Search by Tag" expanded="false">
                <content>
                    <VBox spacing="10">
                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                        <HBox spacing="10">
                            <Label text="Tag Type:"/>
                            <TextField fx:id="tagType"
                                       promptText="person / location / etc."/>
                        </HBox>

                        <HBox spacing="10">
                            <Label text="Tag Value:"/>
                            <TextField fx:id="tagValue"
                                       promptText="john / paris / etc."/>
                        </HBox>
                    </VBox>
                </content>
            </TitledPane>

            <!-- SEARCH BUTTON -->
            <Button text="Search"
                    onAction="#doSearch"
                    prefWidth="150"
                    style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

            <!-- RESULTS -->
            <Label text="Search Results:"
                   style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

            <ListView fx:id="resultsList"
                      prefHeight="300"/>

            <!-- SAVE RESULTS -->
            <Button text="Create Album From Results"
                    prefWidth="250"
                    style="-fx-font-size: 14px;"
                    onAction="#createAlbumFromResults"/>
        </VBox>
    </center>

</BorderPane>
