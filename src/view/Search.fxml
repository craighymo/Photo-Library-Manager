<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.Search"
            prefWidth="700" prefHeight="500">

    <top>
        <VBox spacing="8" style="-fx-padding: 10;">
            <children>

                <Label text="Search Photos">
                    <font>
                        <Font name="Verdana" size="18" />
                    </font>
                </Label>

                
                <HBox spacing="8">
                    <children>
                        <Label text="Date range:" />
                        <Label text="From:" />
                        <DatePicker fx:id="fromDatePicker" />
                        <Label text="To:" />
                        <DatePicker fx:id="toDatePicker" />
                    </children>
                </HBox>

                <Separator />

                
                <Label text="Tag search (leave second tag empty for single-tag search)" />

                <HBox spacing="8">
                    <children>
                        <Label text="Tag 1:" />
                        <TextField fx:id="tagName1" promptText="type (e.g. person)" />
                        <TextField fx:id="tagValue1" promptText="value (e.g. alice)" />
                    </children>
                </HBox>

                <HBox spacing="8">
                    <children>
                        <Label text="Tag 2:" />
                        <TextField fx:id="tagName2" promptText="type (optional)" />
                        <TextField fx:id="tagValue2" promptText="value (optional)" />
                    </children>
                </HBox>

                <HBox spacing="8">
                    <children>
                        <Label text="Combine tags:" />
                        <RadioButton fx:id="andRadio" text="AND" toggleGroup="$tagGroup" />
                        <RadioButton fx:id="orRadio" text="OR" toggleGroup="$tagGroup" />
                        <Label text="(ignored if only Tag 1 is used)" />
                    </children>
                </HBox>

                <HBox spacing="8">
                    <children>
                        <Button fx:id="searchButton" text="Search" onAction="#onSearch" />
                        <Button fx:id="backButton" text="Back to Albums" onAction="#onBack" />
                        <Button fx:id="createAlbumButton" text="Create Album from Results"
                                onAction="#onCreateAlbum" disable="true" />
                        <Label fx:id="statusLabel" text="" />
                    </children>
                </HBox>

            </children>
        </VBox>
    </top>

    <center>
        <ListView fx:id="resultList" />
    </center>

</BorderPane>
